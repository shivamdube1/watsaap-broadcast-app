# Server Configuration
PORT=3000

# Security (Set this to a secure random string for production)
API_KEY=admin123

# Login Credentials
LOGIN_USERNAME=admin
LOGIN_PASSWORD=suraj

# ── PRODUCTION (RENDER / CLOUD) SETTINGS ──────────────────────────
# MongoDB Atlas Connection String (Required for Render)
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/watsaap_broadcast

# Your Render Web Service URL (Required for Keep-Alive)
RENDER_EXTERNAL_URL=https://watsaap-broadcast.onrender.com

# ── BROADCASTING SPEED CONFIGURATION ──────────────────────────────
# Minimum delay (seconds) between messages
MESSAGE_DELAY_MIN=4
# Maximum randomized delay (seconds) between messages 
MESSAGE_DELAY_MAX=9
# Number of messages before taking a longer break
BATCH_SIZE=35
# Duration (seconds) of the break between batches
BATCH_DELAY=30
