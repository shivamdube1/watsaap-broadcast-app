# Server Configuration
PORT=3000

# Security
# Set this to a secure random string for production
API_KEY=admin123

# Login Credentials
LOGIN_USERNAME=your_username
LOGIN_PASSWORD=your_secure_password

# Broadcasting Speed Configuration
# Minimum delay (seconds) between messages
MESSAGE_DELAY_MIN=4
# Maximum randomized delay (seconds) between messages 
MESSAGE_DELAY_MAX=9
# Number of messages before taking a longer break
BATCH_SIZE=35
# Duration (seconds) of the break between batches
BATCH_DELAY=30
