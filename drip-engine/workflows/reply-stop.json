    },
    "IMAP: Fetch Last Hour Emails": {
      "main": [[{"node": "Code: Extract Sender Emails", "type": "main", "index": 0}]]
    },
    "Code: Extract Sender Emails": {
      "main": [[{"node": "PG: Find Matching Sequences", "type": "main", "index": 0}]]
    },
    "PG: Find Matching Sequences": {
