# ============================================================
#  Drip Engine — Environment Variables
#  Copy this to .env and fill in every value before starting
# ============================================================

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=drip_user
POSTGRES_PASSWORD=change_me_super_secret
POSTGRES_DB=drip_engine

# ── n8n Basic Auth ───────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password

# ── n8n Encryption (generate with: openssl rand -hex 32) ─────
N8N_ENCRYPTION_KEY=replace_with_64_hex_chars_generated_by_openssl_rand_hex_32

# ── Public Webhook URL (no trailing slash) ────────────────────
# Use your public domain, or an ngrok URL for local dev
# e.g. https://n8n.yourdomain.com  or  https://abc123.ngrok.app
WEBHOOK_URL=https://YOUR_PUBLIC_N8N_URL

# ── Brevo (Sendinblue) ESP ───────────────────────────────────
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Default Sender Identity ───────────────────────────────────
# Used in campaigns where from_email is not overridden
DEFAULT_FROM_EMAIL=you@yourdomain.com
DEFAULT_FROM_NAME=Your Name

# ── IMAP (for reply detection, per-campaign) ──────────────────
# These are your defaults; per-campaign values are stored in DB
IMAP_HOST=imap.gmail.com
IMAP_USER=your-reply-mailbox@gmail.com
IMAP_PASSWORD=your_imap_app_password

# ── HMAC Secret (unsubscribe token signing) ───────────────────
# Generate with: openssl rand -hex 32
UNSUB_HMAC_SECRET=replace_with_64_hex_chars_for_hmac_signing

# ── Optional: AWS SES fallback (not wired in base workflows) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=
